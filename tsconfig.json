{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "jsxImportSource": "astro",
        "paths": {
            "@/*": ["./src/*"],
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@pages/*": ["./src/pages/*"],
            "@utils/*": ["./src/utils/*"]
        }
    },
    "include": ["src"]
}
