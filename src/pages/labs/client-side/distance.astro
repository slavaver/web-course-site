---
import CourseLayout from "@layouts/CourseLayout.astro";
import { getCollection } from "astro:content";
import { filterCourse } from "@utils/courses";

const filter = filterCourse("2024", "distance");
const course = await getCollection("clientSide", filter);
const lectures = await getCollection("clientSideLectures");

course.forEach((item) => {
    item.id = "client-side/" + item.id;
});
const items = Object.groupBy(
    [...course, ...lectures.slice(0, 8)],
    ({ data }) => data.type
);
---

<CourseLayout
    title="Веб-разработка на  стороне клиента"
    description="Изучаем основы работы с типами и язык TypeScript, а также осваиваем применение фреймворка Vue"
    data={items}
/>
