---

<div class="block">
    <button
        type="button"
        id="back-to-top-btn"
        aria-label="Кнопка наверх"
        class="back-to-top-btn hidden"
        tabindex="1"
        ><svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="back-to-top-btn__svg">
            <path
                fill-rule="evenodd"
                d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm.53 5.47a.75.75 0 00-1.06 0l-3 3a.75.75 0 101.06 1.06l1.72-1.72v5.69a.75.75 0 001.5 0v-5.69l1.72 1.72a.75.75 0 101.06-1.06l-3-3z"
                clip-rule="evenodd"></path>
        </svg>
    </button>
</div>

<script>
    if (document.contains(document.getElementById("back-to-top-btn"))) {
        const button = document.getElementById("back-to-top-btn");
        if (button) {
            window.addEventListener("scroll", () => {
                if (window.scrollY > 200) {
                    button.classList.add("block");
                    button.classList.remove("hidden");
                } else {
                    button.classList.add("hidden");
                    button.classList.remove("block");
                }
            });

            button.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth",
                });
            });
        }
    }
</script>

<style>
    .back-to-top-btn {
        animation: fade-in 300ms linear 1;
        display: block;
        z-index: 1;
        right: 1.25rem;
        bottom: 1.25rem;
        position: fixed;
    }

    .hidden {
        display: none;
    }

    .back-to-top-btn__svg {
        width: 4rem;
        height: 4rem;
        fill: var(--color-bg-accent-second);
    }

    @keyframes fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>
