---
import Heading from "@components/Heading.astro";
import BaseLayoutSnow from "./BaseLayoutSnow.astro";
import CourseImportantSection from "@components/CourseSections/CourseImportantSection.astro";
import CourseExercisesSection from "@/components/CourseSections/CourseExercisesSection.astro";
import CourseLectureSection from "@/components/CourseSections/CourseLectureSection.astro";
import CourseRkSection from "@/components/CourseSections/CourseRkSection.astro";

const { title, description, data } = Astro.props;
---

<BaseLayoutSnow>
    <Heading title={title} description={description} />
    {data.important && <CourseImportantSection items={data.important} />}
    {data.labs && <CourseExercisesSection items={data.labs} />}
    {data.practice && <CourseExercisesSection items={data.practice} />}
    {data.lecture && <CourseLectureSection items={data.lecture} />}
    {data.rk && <CourseRkSection items={data.rk} />}
</BaseLayoutSnow>
